# Local application config (used when running Python directly on the host)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Container-internal application config (used when running Python in Docker)
APP_POSTGRES_HOST=pgdatabase
APP_POSTGRES_PORT=5432

# PostgreSQL database for GDELT data
POSTGRES_DB=gdelt
POSTGRES_USER=root
POSTGRES_PASSWORD=root

# pgAdmin
PGADMIN_DEFAULT_EMAIL=root@root.ch
PGADMIN_DEFAULT_PASSWORD=root

# Kestra metadata database
KESTRA_POSTGRES_DB=kestra
KESTRA_POSTGRES_USER=kestra
KESTRA_POSTGRES_PASSWORD=k3str4

# Kestra UI basic auth
KESTRA_BASIC_AUTH_USERNAME=admin@kestra.io
KESTRA_BASIC_AUTH_PASSWORD=Admin1234!

# Kestra URL
KESTRA_URL=http://localhost:8080/

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# General
LOG_LEVEL=INFO
UV_LINK_MODE=copy
