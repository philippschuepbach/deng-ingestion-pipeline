          "rawSql": "WITH latest_window AS (\n  SELECT MAX(time_window_start) AS max_ts\n  FROM public.risk_alerts_gold\n  WHERE $__timeFilter(time_window_start)\n)\nSELECT\n  country_name,\n  weighted_instability_score\nFROM public.risk_alerts_gold\nWHERE time_window_start = (SELECT max_ts FROM latest_window)\nORDER BY weighted_instability_score DESC\nLIMIT 10;",
