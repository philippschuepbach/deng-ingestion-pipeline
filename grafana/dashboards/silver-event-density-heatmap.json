          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\r\n    es.event_added_ts AS time,\r\n    CAST(es.focus_geo_lat AS DOUBLE PRECISION) AS latitude,\r\n    CAST(es.focus_geo_long AS DOUBLE PRECISION) AS longitude,\r\n    CASE\r\n        WHEN es.is_conflict_related THEN 3.0\r\n        WHEN es.is_protest_related THEN 2.0\r\n        WHEN es.is_diplomatic_tension_related THEN 1.0\r\n        ELSE 0.5\r\n    END AS weight,\r\n    es.focus_country_code,\r\n    es.focus_location_name,\r\n    es.event_code,\r\n    es.goldstein_scale\r\nFROM public.events_silver es\r\nWHERE $__timeFilter(es.event_added_ts)\r\n  AND es.focus_geo_lat IS NOT NULL\r\n  AND es.focus_geo_long IS NOT NULL\r\n  AND es.focus_country_code IS NOT NULL;",
