      "targets": [
        {
          "dataset": "",
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH country_points AS (\r\n    SELECT\r\n        es.focus_country_code AS country_code,\r\n        CAST(AVG(es.focus_geo_lat) AS DOUBLE PRECISION) AS latitude,\r\n        CAST(AVG(es.focus_geo_long) AS DOUBLE PRECISION) AS longitude\r\n    FROM public.events_silver es\r\n    WHERE $__timeFilter(es.event_added_ts)\r\n      AND es.focus_country_code IS NOT NULL\r\n      AND es.focus_geo_lat IS NOT NULL\r\n      AND es.focus_geo_long IS NOT NULL\r\n    GROUP BY es.focus_country_code\r\n)\r\nSELECT\r\n    rag.time_window_start,\r\n    rag.country_name,\r\n    rag.country_code,\r\n    cp.latitude,\r\n    cp.longitude,\r\n    CAST(rag.weighted_instability_score AS DOUBLE PRECISION) AS weighted_instability_score,\r\n    rag.total_event_count,\r\n    rag.protest_event_count,\r\n    rag.conflict_event_count,\r\n    rag.diplomatic_tension_event_count,\r\n    CAST(rag.avg_goldstein_scale AS DOUBLE PRECISION) AS avg_goldstein_scale\r\nFROM public.risk_alerts_gold rag\r\nJOIN country_points cp\r\n  ON cp.country_code = rag.country_code\r\nWHERE $__timeFilter(rag.time_window_start)\r\n  AND rag.is_alert = true\r\nORDER BY rag.time_window_start DESC, rag.weighted_instability_score DESC;",
          "refId": "A",
          "sql": {
            "columns": [
              {
                "parameters": [],
                "type": "function"
              }
            ],
            "groupBy": [
              {
                "property": {
                  "type": "string"
                },
                "type": "groupBy"
              }
            ],
            "limit": 50
          }
        }
      ],
      "title": "Latest Alert Window Geomap",
      "type": "geomap"
    }
